<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_token_wallet" model="ir.ui.view">
        <field name="name">product.template.form.token.wallet</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='sales']" position="inside">
                <group string="Token Wallet">
                    <group>
                        <field name="token_wallet_role"/>
                        <field name="token_qty"
                               invisible="not token_wallet_role"
                               required="token_wallet_role"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
