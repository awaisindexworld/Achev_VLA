<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_elearning_detail_tree" model="ir.ui.view">
        <field name="name">elearning.detail.tree</field>
        <field name="model">elearning.detail</field>
        <field name="arch" type="xml">
            <list string="Details">
                <field name="name"/>
                <field name="skill_type"/>
            </list>
        </field>
    </record>

    <record id="view_elearning_detail_form" model="ir.ui.view">
        <field name="name">elearning.detail.form</field>
        <field name="model">elearning.detail</field>
        <field name="arch" type="xml">
            <form string="Details">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="skill_type" widget="radio" options="{'horizontal': true}"/>
                    </group>
                    <notebook>
                        <page string="Lines">
                            <field name="line_ids" context="{'default_detail_id': id}">
                                <list string="Lines">
                                    <field name="sequence" widget="handle"/>
                                    <field name="clb"/>
                                    <field name="can_do_statement_left" string="Can do statement Left"/>
                                    <field name="can_do_statement_right" string="Can do statement Right"/>
                                    <field name="recommendation"/>
                                </list>
                                <form string="Detail Line">
                                    <sheet>
                                        <group>
                                            <field name="clb"/>
                                        </group>
                                        <group string="Can do statement" col="2">
                                            <field name="can_do_statement_left"/>
                                            <field name="can_do_statement_right"/>
                                        </group>
                                        <group>
                                            <field name="recommendation" widget="text"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_elearning_detail_line_tree" model="ir.ui.view">
        <field name="name">elearning.detail.line.tree</field>
        <field name="model">elearning.detail.line</field>
        <field name="arch" type="xml">
            <list string="Detail Lines">
                <field name="sequence" widget="handle"/>
                <field name="detail_id"/>
                <field name="clb"/>
                <field name="can_do_statement_left" string="Can do statement Left"/>
                <field name="can_do_statement_right" string="Can do statement Right"/>
                <field name="recommendation"/>
            </list>
        </field>
    </record>

    <record id="view_elearning_detail_line_form" model="ir.ui.view">
        <field name="name">elearning.detail.line.form</field>
        <field name="model">elearning.detail.line</field>
        <field name="arch" type="xml">
            <form string="Detail Line">
                <sheet>
                    <group>
                        <field name="detail_id" invisible="1"/>
                        <field name="clb"/>
                    </group>
                    <group string="Can do statement" col="2">
                        <field name="can_do_statement_left"/>
                        <field name="can_do_statement_right"/>
                    </group>
                    <group>
                        <field name="recommendation" widget="text"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_elearning_detail" model="ir.actions.act_window">
        <field name="name">Details</field>
        <field name="res_model">elearning.detail</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_elearning_detail"
        name="Details"
        parent="website_slides.website_slides_menu_configuration"
        action="action_elearning_detail"
        sequence="20"
        groups="website_slides.group_website_slides_officer"
    />
</odoo>
